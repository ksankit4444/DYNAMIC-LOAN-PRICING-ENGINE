      },
      "targets": [
        {
          "rawSql": "SELECT date_trunc('day', created_at) as time, COUNT(*) as applications, AVG(pd_ensemble) as avg_pd FROM loan_applications WHERE $__timeFilter(created_at) GROUP BY 1 ORDER BY 1;",
