# =====
# Dynamic Loan Pricing Engine — Environment Variables
# =====
# Copy this to .env and fill in your actual keys.
# This file is .gitignore'd — never commit API keys.

# --- Google Gemini (ChatGoogleGenerativeAI) ---
GOOGLE_API_KEY=your_gemini_api_key_here

# --- Tavily Search (Market Intelligence) ---
TAVILY_API_KEY=your_tavily_api_key_here

# --- PostgreSQL (if different from config.yaml defaults) ---
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=loan_pricing_engine
# DB_USER=postgres
# DB_PASSWORD=password
